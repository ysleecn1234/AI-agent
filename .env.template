# ============================================
# LLM API Keys (Required)
# ============================================

# 1. OpenAI (필수)
# - 용도: GPT-4o, GPT-4o-mini, Embedding(text-embedding-3-small)
# - 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# 2. Anthropic (선택)
# - 용도: Claude-3.5-Sonnet, Claude-3-Haiku
# - 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# 3. Google (선택)
# - 용도: Gemini-1.5-Pro, Gemini-1.5-Flash
# - 발급: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# 4. Perplexity (선택 - 프리미엄 모델)
# - 용도: Sonar Pro (실시간 검색)
# - 발급: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# ============================================
# Database Configuration (Docker Default)
# ============================================

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_hub
POSTGRES_USER=aiagent
POSTGRES_PASSWORD=aiagent123

# Milvus (Vector DB)
MILVUS_HOST=localhost
